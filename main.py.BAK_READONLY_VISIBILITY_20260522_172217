from fastapi import FastAPI
from ibapi.client import EClient
from ibapi.wrapper import EWrapper
import threading
import time
import os

app = FastAPI()

IB_HOST = os.getenv("IB_HOST", "172.18.0.1")
IB_PORT = int(os.getenv("IB_PORT", "4002"))
IB_CLIENT_ID = int(os.getenv("IB_CLIENT_ID", "12001"))
EXECUTION_MODE = os.getenv("EXECUTION_MODE", "READ_ONLY")


class IBApp(EWrapper, EClient):
    def __init__(self):
        EClient.__init__(self, self)
        self.connected_flag = False

    def nextValidId(self, orderId):
        self.connected_flag = True


@app.get("/")
def root():
    return {
        "service": "execution_service",
        "mode": EXECUTION_MODE
    }


@app.get("/health")
def health():
    return {
        "service": "execution_service",
        "status": "healthy"
    }


@app.get("/ib/status")
def ib_status():
    app_ib = IBApp()

    app_ib.connect(
        IB_HOST,
        IB_PORT,
        clientId=IB_CLIENT_ID
    )

    thread = threading.Thread(
        target=app_ib.run,
        daemon=True
    )
    thread.start()

    time.sleep(3)

    result = {
        "connected": app_ib.isConnected(),
        "api_ready": app_ib.connected_flag,
        "host": IB_HOST,
        "port": IB_PORT,
        "mode": EXECUTION_MODE
    }

    app_ib.disconnect()

    return result
