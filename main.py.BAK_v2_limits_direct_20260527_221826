from pydantic import BaseModel
from datetime import datetime
import os

AUDIT_LOG_PATH = "/tmp/execution_audit.jsonl"


class PaperOrderRequest(BaseModel):
    symbol: str
    side: str
    quantity: float
    order_type: str = "MARKET"


@app.post("/orders/paper")
def paper_order(req: PaperOrderRequest):

    limits = load_risk_limits()

    symbol = req.symbol.upper()
    side = req.side.upper()

    allowed_symbols = limits.get("allowed_symbols", [])
    blocked_sides = limits.get("blocked_sides", [])
    max_qty = float(limits.get("max_quantity", 0))

    checks = {
        "symbol_allowed": symbol in allowed_symbols,
        "side_allowed": side not in blocked_sides,
        "qty_allowed": req.quantity <= max_qty,
        "read_only_mode": EXECUTION_MODE == "READ_ONLY",
        "paper_mode": EXECUTION_MODE == "PAPER_ONLY",
        "live_mode": EXECUTION_MODE == "LIVE_ENABLED"
    }

    reject_reasons = []

    if not checks["symbol_allowed"]:
        reject_reasons.append("SYMBOL_NOT_ALLOWED")

    if not checks["side_allowed"]:
        reject_reasons.append("SIDE_BLOCKED")

    if not checks["qty_allowed"]:
        reject_reasons.append("QUANTITY_EXCEEDS_LIMIT")

    approved = (
        checks["symbol_allowed"] and
        checks["side_allowed"] and
        checks["qty_allowed"] and
        checks["paper_mode"]
    )

    if not checks["paper_mode"]:
        reject_reasons.append("PAPER_MODE_NOT_ENABLED")

    record = {
        "timestamp_utc": datetime.utcnow().isoformat(),
        "mode": EXECUTION_MODE,
        "approved": approved,
        "reject_reasons": reject_reasons,
        "checks": checks,
        "order": {
            "symbol": symbol,
            "side": side,
            "quantity": req.quantity,
            "order_type": req.order_type
        },
        "execution": "PAPER_SIMULATED_ONLY_NO_LIVE_ORDER"
    }

    with open(AUDIT_LOG_PATH, "a") as f:
        f.write(json.dumps(record) + "\n")

    return record


@app.get("/orders/audit")
def audit_orders():

    if not os.path.exists(AUDIT_LOG_PATH):
        return {
            "count": 0,
            "orders": []
        }

    rows = []

    with open(AUDIT_LOG_PATH, "r") as f:
        for line in f.readlines()[-100:]:
            try:
                rows.append(json.loads(line))
            except:
                pass

    return {
        "count": len(rows),
        "orders": rows
    }



@app.post("/orders/pretrade")
def pretrade_order(req: PaperOrderRequest):

    limits = load_risk_limits()

    symbol = req.symbol.upper()
    side = req.side.upper()

    allowed_symbols = limits.get("allowed_symbols", [])
    blocked_sides = limits.get("blocked_sides", [])
    max_qty = float(limits.get("max_quantity", 0))

    checks = {
        "symbol_allowed": symbol in allowed_symbols,
        "side_allowed": side not in blocked_sides,
        "qty_allowed": req.quantity <= max_qty,
        "read_only_mode": EXECUTION_MODE == "READ_ONLY",
        "paper_mode": EXECUTION_MODE == "PAPER_ONLY",
        "live_mode": EXECUTION_MODE == "LIVE_ENABLED",
        "kill_switch_blocks_live": True
    }

    reject_reasons = []

    if not checks["symbol_allowed"]:
        reject_reasons.append("SYMBOL_NOT_ALLOWED")

    if not checks["side_allowed"]:
        reject_reasons.append("SIDE_BLOCKED")

    if not checks["qty_allowed"]:
        reject_reasons.append("QUANTITY_EXCEEDS_LIMIT")

    if checks["read_only_mode"]:
        reject_reasons.append("READ_ONLY_MODE_BLOCKS_LIVE_EXECUTION")

    paper_approved = (
        checks["symbol_allowed"] and
        checks["side_allowed"] and
        checks["qty_allowed"] and
        checks["paper_mode"]
    )

    live_approved = (
        checks["symbol_allowed"] and
        checks["side_allowed"] and
        checks["qty_allowed"] and
        checks["live_mode"]
    )

    record = {
        "timestamp_utc": datetime.utcnow().isoformat(),
        "mode": EXECUTION_MODE,
        "paper_approved": paper_approved,
        "paper_approved": paper_approved,
        "live_approved": live_approved,
        "reject_reasons": reject_reasons,
        "checks": checks,
        "order": {
            "symbol": symbol,
            "side": side,
            "quantity": req.quantity,
            "order_type": req.order_type
        },
        "execution": "BLOCKED_PRETRADE_ONLY_NO_LIVE_ORDER"
    }

    with open(AUDIT_LOG_PATH, "a") as f:
        f.write(json.dumps(record) + "\n")

    return record



@app.post("/orders/route")
def route_order(req: PaperOrderRequest):
    pre = pretrade_order(req)

    live_enabled = EXECUTION_MODE == "LIVE_ENABLED"
    kill = risk_kill_switch()
    kill_on = bool(kill.get("kill_switch_enabled"))

    route_allowed = (
        pre.get("live_approved") is True and
        live_enabled and
        not kill_on
    )

    record = {
        "timestamp_utc": datetime.utcnow().isoformat(),
        "mode": EXECUTION_MODE,
        "route_allowed": route_allowed,
        "pretrade": pre,
        "kill_switch_enabled": kill_on,
        "execution": "ROUTE_BLOCKED_NO_LIVE_ORDER"
    }

    with open(AUDIT_LOG_PATH, "a") as f:
        f.write(json.dumps(record) + "\n")

    return record



@app.get("/system/mode")
def system_mode():

    kill = risk_kill_switch()

    return {
        "service": "execution_service",
        "execution_mode": EXECUTION_MODE,
        "read_only": EXECUTION_MODE == "READ_ONLY",
        "paper_enabled": EXECUTION_MODE == "PAPER_ONLY",
        "live_enabled": EXECUTION_MODE == "LIVE_ENABLED",
        "kill_switch_enabled": bool(kill.get("kill_switch_enabled")),
        "routing_active": EXECUTION_MODE == "LIVE_ENABLED" and not bool(kill.get("kill_switch_enabled"))
    }



@app.get("/safety/final-check")
def safety_final_check():
    mode = system_mode()
    safety = safety_summary()

    can_send_live_orders = (
        mode.get("live_enabled") is True and
        mode.get("routing_active") is True and
        safety.get("ib_connected") is True and
        safety.get("ib_api_ready") is True and
        safety.get("account_allowlisted") is True and
        safety.get("kill_switch_enabled") is False
    )

    return {
        "service": "execution_service",
        "can_send_live_orders": can_send_live_orders,
        "mode": mode,
        "safety": safety,
        "verdict": "LIVE_ORDERING_BLOCKED" if not can_send_live_orders else "LIVE_ORDERING_ENABLED"
    }



@app.get("/system/status")
def system_status():
    mode = system_mode()
    safety = safety_summary()
    final = safety_final_check()

    try:
        pos = account_positions()
    except Exception as e:
        pos = {
            "service": "execution_service",
            "error": str(e),
            "positions": [],
        }

    return {
        "service": "execution_service",
        "status": "production_prep_locked",
        "can_send_live_orders": final.get("can_send_live_orders") is True,
        "verdict": final.get("verdict"),
        "mode": mode,
        "safety": safety,
        "positions": pos,
        "final_check": final,
    }
